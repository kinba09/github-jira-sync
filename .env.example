# Service
PORT=3000

# Arcade
ARCADE_API_KEY=your_arcade_api_key
ARCADE_USER_ID=you@example.com

# GitHub webhook validation (recommended)
GITHUB_WEBHOOK_SECRET=replace_with_same_secret_used_in_github_webhook

# Jira webhook validation (optional but recommended)
# Send this as header x-jira-webhook-token or query ?token=...
JIRA_WEBHOOK_TOKEN=replace_with_jira_webhook_token

# Branch parsing
# Default finds keys like JIRA-123 anywhere in the branch name.
JIRA_ISSUE_REGEX=[A-Z][A-Z0-9]+-\d+

# If true, branch name must exactly match the Jira key (example: JIRA-123)
REQUIRE_EXACT_BRANCH_KEY=false

# Marker used for dedupe to avoid duplicate Jira comments per PR
JIRA_COMMENT_MARKER=[github-jira-sync]

# Delay before alert check (seconds)
ALERT_DELAY_SECONDS=60

# Jira status keywords considered "closed" when statusCategory is unavailable
JIRA_CLOSED_STATUS_KEYWORDS=done,closed,resolved

# Slack destination for mismatch alerts (set either channel or conversation id)
SLACK_ALERT_CHANNEL=engineering-alerts
# SLACK_ALERT_CONVERSATION_ID=C0123456789
